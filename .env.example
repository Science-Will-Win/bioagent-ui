# ============================================================
# AIGEN BioAgent — 환경변수 설정
# 사용법: cp .env.example .env → 값 수정 후 docker-compose up
# ============================================================

# ── 포트 설정 ──
UI_PORT=3000
API_PORT=8000

# ── BE 서버 (B안 외부 배포 시) ──
# BACKEND_EXTERNAL_HOST=api.bioagent.example.com
# BACKEND_EXTERNAL_PORT=443

# ── vLLM 서버 (DGX A100, GPU 6-7) ──
VLLM_HOST=http://host.docker.internal:8080

# ── Langfuse ──
LANGFUSE_HOST=http://langfuse:3100
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
